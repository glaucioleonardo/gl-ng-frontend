{"version":3,"file":"gl-ng-frontend.js","sources":["ng://gl-ng-frontend/lib/core/directives/autofocus/core-directives-autofocus.directive.ts","ng://gl-ng-frontend/lib/core/gl-core.module.ts","ng://gl-ng-frontend/lib/shared/component/input/button/simple/gl-shared-component-input-button-simple.component.ts","ng://gl-ng-frontend/lib/shared/component/input/option/simple/gl-shared-component-input-option-simple.component.ts","ng://gl-ng-frontend/lib/shared/component/input/text/simple/gl-shared-component-input-text-simple.component.ts","ng://gl-ng-frontend/lib/shared/component/title/label/simple/gl-shared-component-title-label-simple.component.ts","ng://gl-ng-frontend/lib/shared/component/input/text/label/gl-shared-component-input-text-label.component.ts","ng://gl-ng-frontend/lib/shared/component/input/text-area/simple/gl-shared-component-input-text-area-simple.component.ts","ng://gl-ng-frontend/lib/shared/component/input/text-area/label/gl-shared-component-input-text-area-label.component.ts","ng://gl-ng-frontend/lib/shared/component/modal/alert/gl-shared-component-modal-alert.service.ts","ng://gl-ng-frontend/lib/shared/component/modal/alert/gl-shared-component-modal-alert.component.ts","ng://gl-ng-frontend/lib/shared/component/modal/header/gl-shared-component-modal-header.component.ts","ng://gl-ng-frontend/lib/shared/component/modal/loading/gl-shared-component-modal-loading.service.ts","ng://gl-ng-frontend/lib/shared/component/modal/loading/gl-shared-component-modal-loading.component.ts","ng://gl-ng-frontend/lib/shared/component/title/page/gl-shared-component-title-page.component.ts","ng://gl-ng-frontend/lib/shared/component/title/label/button/simple/gl-shared-component-title-label-button-simple.component.ts","ng://gl-ng-frontend/lib/shared/component/title/label/button/container/gl-shared-component-title-label-button-container.component.ts","ng://gl-ng-frontend/lib/shared/component/menu/background/gl-shared-component-menu-background.component.ts","ng://gl-ng-frontend/lib/